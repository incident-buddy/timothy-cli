{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | grep -qE '\\.(ts|js)$' && pnpm --dir /home/todokr/git-project/timothy lint 2>/dev/null || true",
            "statusMessage": "Running oxlint..."
          }
        ]
      }
    ]
  }
}
